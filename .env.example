# ============================================================
# HealthSense AI - Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit the real .env file to version control.
# ============================================================

# --- OpenAI ---
# Required by all agent workflows (Coordinator, Booking, Diagnostics, Hospital).
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- Microsoft Graph / SharePoint ---
# Required by Doctor Booking Agent, Diagnostics Agent, and Hospital Comparison Agent
# to read Excel workbooks hosted on SharePoint / OneDrive.
# Register an app at https://portal.azure.com > App registrations.
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-app-client-secret
MICROSOFT_TENANT_ID=your-azure-tenant-id

# --- Microsoft Outlook ---
# Required by Doctor Booking Agent and Diagnostics Agent for sending
# confirmation and reminder emails via Outlook.
# Uses the same Azure AD app registration as above (add Mail.Send permission).
OUTLOOK_CLIENT_ID=your-outlook-client-id
OUTLOOK_CLIENT_SECRET=your-outlook-client-secret

# --- Airtable ---
# Required by the Hospital Comparison Agent to query the
# Hospital_General_Information table.
# Create a personal access token at https://airtable.com/create/tokens
AIRTABLE_API_TOKEN=pat_your-airtable-token-here

# --- n8n (self-hosted only) ---
# These are only needed when running n8n via Docker or self-hosted.
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_HOST=localhost
N8N_ENCRYPTION_KEY=your-random-encryption-key
WEBHOOK_URL=http://localhost:5678/
